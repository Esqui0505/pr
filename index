<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Hoy es un día especial</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}

body{
    font-family: Georgia, serif;
    background: radial-gradient(circle at top,#0f3d2e,#071a14);
    height:100vh;
    overflow:hidden;
    color:white;
}

/* PANTALLAS */
.pantalla{
    position:absolute;
    inset:0;
    display:none;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    opacity:0;
    transition:.8s;
}
.pantalla.activa{opacity:1}

/* LOGIN */
#login{display:flex}
#login input{
    padding:14px;
    width:220px;
    text-align:center;
    border-radius:8px;
    border:2px solid #c77dff;
    margin:15px 0;
}
#login button{
    padding:12px 30px;
    border-radius:30px;
    border:none;
    background:#c77dff;
    color:white;
    cursor:pointer;
    font-weight:bold;
}

/* MENSAJE */
.mensaje{
    width:60%;
    max-width:600px;
    line-height:1.8;
    font-size:1.2rem;
}
.titulo{
    color:#c77dff;
    font-size:3rem;
    margin-bottom:25px;
}

/* PASTEL */
#cake{
    position:relative;
    width:220px;
    height:220px;
    margin-top:30px;
}

/* base */
.cake-base{
    position:absolute;
    bottom:0;
    width:220px;
    height:120px;
    background:#6b3f1d;
    border-radius:20px;
}

/* crema */
.cake-cream{
    position:absolute;
    bottom:100px;
    width:220px;
    height:40px;
    background:#fff3e0;
    border-radius:50%;
}

/* vela */
.candle{
    position:absolute;
    bottom:140px;
    left:50%;
    transform:translateX(-50%);
    width:14px;
    height:50px;
    background:#ff4d4d;
    border-radius:4px;
}

/* flama */
.flame{
    position:absolute;
    bottom:190px;
    left:50%;
    transform:translateX(-50%);
    width:18px;
    height:28px;
    background:radial-gradient(circle,#ffd166 20%,#ff8c00 70%);
    border-radius:50%;
    animation:flame 0.15s infinite alternate;
}

@keyframes flame{
    from{transform:translateX(-50%) scaleY(1)}
    to{transform:translateX(-50%) scaleY(1.2)}
}

.apagada{
    display:none;
}

/* HOJA BLANCA */
.hoja{
    width:80%;
    height:85vh;
    background:#f2e2c4;
    color:#2b2b2b;
    border-radius:8px;
    padding:60px;
    font-size:1.4rem;
    text-align:center;
}
</style>
</head>

<body>

<!-- LOGIN -->
<div class="pantalla activa" id="login">
    <h2>Ingresa el código</h2>
    <input id="codigo" type="password" placeholder="******">
    <button onclick="entrar()">Entrar</button>
</div>

<!-- MENSAJE -->
<div class="pantalla" id="mensaje">
    <div class="mensaje">
        <div class="titulo">Hoy no es un día cualquiera</div>
        <p>Hoy es un día especial.</p>
        <p>No vengo a interrumpir tu vida.</p>
        <p>Ni a remover emociones.</p>
        <p>Solo a dejar algo bonito aquí.</p>
        <p>Un pequeño detalle en un día importante.</p>
    </div>

    <!-- PASTEL -->
    <div id="cake">
        <div class="cake-base"></div>
        <div class="cake-cream"></div>
        <div class="candle"></div>
        <div class="flame" id="flame"></div>
    </div>
</div>

<!-- HOJA -->
<div class="pantalla" id="hoja">
    <div class="hoja">
        🌙  
        <br><br>
        Este espacio es solo para hoy.
        <br><br>
        Feliz cumpleaños 🎂
    </div>
</div>

<script>
const PASS="080305";

/* LOGIN */
function entrar(){
    if(document.getElementById("codigo").value===PASS){
        mostrar("mensaje");
        iniciarMicrofono();
    }else alert("Código incorrecto");
}

/* CAMBIAR PANTALLAS */
function mostrar(id){
    document.querySelectorAll(".pantalla").forEach(p=>{
        p.style.display="none";
        p.classList.remove("activa");
    });

    const el=document.getElementById(id);
    el.style.display="flex";
    setTimeout(()=>el.classList.add("activa"),50);
}

/* SOPLAR VELA */
function iniciarMicrofono(){
navigator.mediaDevices.getUserMedia({audio:true}).then(stream=>{
    const audioContext=new AudioContext();
    const mic=audioContext.createMediaStreamSource(stream);
    const analyser=audioContext.createAnalyser();
    mic.connect(analyser);

    const data=new Uint8Array(analyser.frequencyBinCount);

    function detectar(){
        analyser.getByteFrequencyData(data);
        let volumen=data.reduce((a,b)=>a+b)/data.length;

        if(volumen>35){ // soplido
            document.getElementById("flame").classList.add("apagada");
            setTimeout(()=>mostrar("hoja"),1200);
            stream.getTracks().forEach(t=>t.stop());
            return;
        }
        requestAnimationFrame(detectar);
    }
    detectar();
});
}
</script>

</body>
</html>
